{
  "crons": [
    { "path": "/api/cron-delivery-reminders", "schedule": "0 22 * * *" },
    { "path": "/api/cron-blog-writer", "schedule": "0 23 * * 1,3,5" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },

    { "source": "/blog",        "destination": "/api/blog"                 },
    { "source": "/blog/:slug",  "destination": "/api/blog-post?slug=:slug" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap"              },
    { "source": "/llms.txt",    "destination": "/api/llms"                 },

    { "source": "/delivery/accept/:token", "destination": "/delivery/accept.html?token=:token"  },
    { "source": "/delivery/drop/:token",   "destination": "/delivery/dropoff.html?token=:token" },
    { "source": "/delivery/:token",        "destination": "/delivery/pickup.html?token=:token"  },

    { "source": "/tuner/respond/:token",   "destination": "/tuner/respond.html?token=:token"   },
    { "source": "/tuner/log-date/:token",  "destination": "/tuner/log-date.html?token=:token"  },
    { "source": "/tuner/complete/:token",  "destination": "/tuner/complete.html?token=:token"  },

    { "source": "/portal",                 "destination": "/portal/index.html"     },
    { "source": "/portal/dashboard",       "destination": "/portal/dashboard.html" },

    { "source": "/admin/countersign",      "destination": "/admin/countersign.html" },

    {
      "source": "/js/(.*)",
      "has": [{ "type": "host", "value": "admin.signaturepianos.com.au" }],
      "destination": "/js/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.signaturepianos.com.au" }],
      "destination": "/admin/$1"
    }
  ],
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 20
    },
    "api/marketing-audit.js": { "maxDuration": 300 },
    "api/blog-generate.js": { "maxDuration": 300 },
    "api/run-blog-writer.js": { "maxDuration": 300 },
    "api/cron-blog-writer.js": { "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
