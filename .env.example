# Signature Pianos — environment variables
# -----------------------------------------
# Reference only. The real values live in the Vercel project dashboard
# (Settings → Environment Variables). Never create a real .env file in
# this repo — anything matching .env* is gitignored, but the safest
# habit is to keep secrets entirely out of the working tree.

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email
RESEND_API_KEY=your_resend_api_key
BUSINESS_EMAIL=info@signaturepianos.com.au

# Stripe (add when building checkout)
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
